# ─────────────────────────────────────────────────────────────────────────────
# MoneyPay — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Use Vault / K8s Secrets in staging & production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Spring ───────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local

# ── Database (shared credentials; each service uses its own DB name) ─────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass

# ── Eureka ────────────────────────────────────────────────────────────────────
EUREKA_URI=http://admin:admin@localhost:8761/eureka
EUREKA_USER=admin
EUREKA_PASSWORD=admin

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HMAC-SHA256.
JWT_SECRET=change_this_in_production_must_be_at_least_32_chars
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── Email (for notification-service & alert-service) ─────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Slack (for alert-service) ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Payment Processor Sandbox ────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_test_key
RAZORPAY_KEY_SECRET=your_razorpay_test_secret
